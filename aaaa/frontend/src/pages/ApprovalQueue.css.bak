/* ===========================================================
   Approval Queue Page
   =========================================================== */

.aq-root {
  padding: 28px 32px;
  min-height: 100vh;
  background: #07080f;
  color: #e8eaff;
  font-family: 'Inter', system-ui, sans-serif;
  max-width: 800px;
}

.aq-loading {
  padding: 80px;
  text-align: center;
  color: #444;
  font-size: 13px;
}

/* ─── Header ──────────────────────────────────────────────── */
.aq-header {
  display: flex;
  align-items: center;
  margin-bottom: 6px;
}
.aq-header-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
}
.aq-header-icon { color: #ff6d00; }
.aq-title {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: 2.5px;
  color: #d0d2ff;
  margin: 0;
}
.aq-count {
  background: #ff6d00;
  color: #000;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 10px;
}
.aq-refresh {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 7px;
  color: #666;
  cursor: pointer;
  padding: 6px 8px;
  display: flex;
  align-items: center;
  transition: background 0.2s;
}
.aq-refresh:hover { background: rgba(255,255,255,0.08); color: #aaa; }

.aq-subtitle {
  font-size: 12px;
  color: #444;
  margin: 0 0 24px;
}

/* ─── Empty ───────────────────────────────────────────────── */
.aq-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  padding: 60px 0;
  color: #333;
  font-size: 13px;
}
.aq-empty-icon { color: #2a2a3a; }

/* ─── Cards ───────────────────────────────────────────────── */
.aq-list { display: flex; flex-direction: column; gap: 14px; }

.aq-card {
  background: #0d0d16;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  padding: 20px;
  transition: opacity 0.35s, transform 0.35s;
}
.aq-card.dismissing {
  opacity: 0;
  transform: translateX(30px);
}

.aq-card-top { margin-bottom: 10px; }

.aq-card-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}
.aq-type-badge {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.8px;
  padding: 3px 8px;
  border-radius: 4px;
  text-transform: uppercase;
}
.aq-type-badge.product {
  background: rgba(0,229,255,0.1);
  color: #00e5ff;
  border: 1px solid rgba(0,229,255,0.2);
}
.aq-type-badge.affiliate {
  background: rgba(255,64,129,0.1);
  color: #ff4081;
  border: 1px solid rgba(255,64,129,0.2);
}
.aq-card-time {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  color: #333;
  margin-left: auto;
}

.aq-card-title {
  font-size: 16px;
  font-weight: 700;
  color: #d8daff;
  margin: 0 0 4px;
  line-height: 1.3;
}
.aq-niche {
  font-size: 11px;
  color: #555;
}

/* ─── Platforms ───────────────────────────────────────────── */
.aq-platforms {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 14px;
}
.aq-platform-chip {
  font-size: 10px;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 5px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  color: #888;
}

/* ─── Details ─────────────────────────────────────────────── */
.aq-details {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 20px;
  margin-bottom: 14px;
}
.aq-detail {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: #666;
}
.aq-detail strong { color: #aab; }
.aq-budget { color: #69ff47; font-weight: 600; font-size: 12px; }

/* ─── Content preview ─────────────────────────────────────── */
.aq-content-preview {
  background: rgba(0,0,0,0.3);
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 8px;
  padding: 12px 14px;
  margin-bottom: 16px;
}
.aq-preview-label {
  font-size: 9px;
  letter-spacing: 1.5px;
  color: #333;
  font-weight: 700;
  margin-bottom: 8px;
}
.aq-preview-list { display: flex; flex-direction: column; gap: 7px; }
.aq-preview-item {
  display: flex;
  gap: 10px;
  align-items: baseline;
}
.aq-preview-platform {
  font-size: 10px;
  font-weight: 700;
  color: #555;
  min-width: 72px;
  flex-shrink: 0;
}
.aq-preview-caption {
  font-size: 11.5px;
  color: #888;
  line-height: 1.4;
}
.aq-preview-more {
  font-size: 10px;
  color: #333;
  margin-top: 2px;
}

/* ─── Actions ─────────────────────────────────────────────── */
.aq-actions {
  display: flex;
  gap: 10px;
}
.aq-btn-approve,
.aq-btn-reject {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 9px 18px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  transition: all 0.2s;
}
.aq-btn-approve {
  background: linear-gradient(135deg, #00c853, #00e5ff);
  color: #000;
}
.aq-btn-approve:hover { opacity: 0.9; transform: translateY(-1px); }
.aq-btn-reject {
  background: rgba(255,80,80,0.1);
  border: 1px solid rgba(255,80,80,0.25);
  color: #ff5050;
}
.aq-btn-reject:hover { background: rgba(255,80,80,0.18); }
.aq-btn-approve:disabled,
.aq-btn-reject:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
