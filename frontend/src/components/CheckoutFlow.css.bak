/* CheckoutFlow.css - Professional checkout styling */

.checkout-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
  padding: 20px;
}

.checkout-container {
  background: linear-gradient(135deg, #2d2d44 0%, #1a1a2e 100%);
  border: 1px solid #333;
  border-radius: 16px;
  max-width: 500px;
  width: 100%;
  position: relative;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
}

.checkout-close {
  position: absolute;
  top: 16px;
  right: 16px;
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #fff;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 20px;
  transition: all 0.2s ease;
  z-index: 10;
}

.checkout-close:hover {
  background: rgba(255, 255, 255, 0.2);
}

/* Header */
.checkout-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 32px 24px 8px;
  color: #00d4ff;
}

.checkout-header h1 {
  font-size: 22px;
  font-weight: 700;
  margin: 0;
}

/* Steps */
.checkout-steps {
  display: flex;
  padding: 16px 24px;
  gap: 16px;
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.step {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #a0aec0;
  position: relative;
}

.step span {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid #333;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  flex-shrink: 0;
}

.step.active span {
  background: linear-gradient(135deg, #00d4ff 0%, #7c3aed 100%);
  border-color: #00d4ff;
  color: #fff;
}

.step:not(:last-child)::after {
  content: '';
  position: absolute;
  width: 8px;
  height: 2px;
  background: #333;
  right: -12px;
  top: 13px;
}

/* Content */
.checkout-content {
  padding: 24px;
}

.step-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* Product Summary */
.product-summary {
  display: flex;
  gap: 16px;
  padding: 16px;
  background: rgba(0, 212, 255, 0.05);
  border: 1px solid rgba(0, 212, 255, 0.1);
  border-radius: 8px;
}

.summary-image {
  width: 80px;
  height: 80px;
  border-radius: 6px;
  object-fit: cover;
  flex-shrink: 0;
}

.summary-info {
  flex: 1;
}

.summary-info h3 {
  font-size: 15px;
  font-weight: 600;
  margin: 0 0 4px 0;
  color: #fff;
}

.summary-info p {
  font-size: 13px;
  color: #a0aec0;
  margin: 0 0 8px 0;
  line-height: 1.4;
}

.summary-price {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: 600;
}

.original-price {
  color: #a0aec0;
  text-decoration: line-through;
  font-size: 13px;
}

.final-price {
  color: #10b981;
}

/* Order Breakdown */
.order-breakdown {
  padding: 16px;
  background: rgba(0, 212, 255, 0.05);
  border: 1px solid rgba(0, 212, 255, 0.1);
  border-radius: 8px;
}

.order-breakdown h4 {
  font-size: 13px;
  font-weight: 600;
  color: #00d4ff;
  margin: 0 0 12px 0;
  text-transform: uppercase;
}

.breakdown-row {
  display: flex;
  justify-content: space-between;
  font-size: 13px;
  color: #cbd5e0;
  padding: 8px 0;
  border-bottom: 1px solid rgba(0, 212, 255, 0.1);
}

.breakdown-row.total {
  border-bottom: none;
  padding-top: 8px;
  margin-top: 4px;
  border-top: 1px solid rgba(0, 212, 255, 0.2);
  font-weight: 600;
  color: #fff;
}

/* Email Input */
.email-input {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.email-input label {
  font-size: 13px;
  font-weight: 600;
  color: #00d4ff;
}

.email-input input {
  padding: 10px 12px;
  background: rgba(0, 212, 255, 0.05);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 6px;
  color: #fff;
  font-size: 13px;
}

.email-input input:focus {
  outline: none;
  border-color: #00d4ff;
  box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
}

.email-input small {
  font-size: 11px;
  color: #718096;
}

/* Error Message */
.error-message {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.2);
  border-radius: 6px;
  color: #ef4444;
  font-size: 13px;
}

/* Card Element */
.card-element-wrapper {
  padding: 12px;
  background: rgba(0, 212, 255, 0.05);
  border: 1px solid rgba(0, 212, 255, 0.2);
  border-radius: 6px;
}

/* Trust Badges */
.trust-badges {
  text-align: center;
  font-size: 12px;
  color: #718096;
}

/* Actions */
.actions {
  display: flex;
  gap: 12px;
}

.btn-primary,
.btn-secondary {
  flex: 1;
  padding: 12px 16px;
  border: none;
  border-radius: 6px;
  font-weight: 600;
  cursor: pointer;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #00d4ff 0%, #7c3aed 100%);
  color: #fff;
}

.btn-primary:hover:not(:disabled) {
  box-shadow: 0 6px 20px rgba(0, 212, 255, 0.3);
  transform: translateY(-2px);
}

.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: #fff;
}

.btn-secondary:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.15);
}

.btn-full {
  width: 100%;
}

/* Processing State */
.step-content.processing {
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.processing-animation {
  margin-bottom: 24px;
}

.spinner-circle {
  width: 60px;
  height: 60px;
  border: 4px solid rgba(0, 212, 255, 0.2);
  border-top-color: #00d4ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.spinner {
  animation: spin 1s linear infinite;
  display: inline-block;
}

.step-content.processing h3 {
  margin: 0 0 8px 0;
}

.step-content.processing p {
  color: #a0aec0;
  font-size: 13px;
  margin: 0;
}

/* Success State */
.step-content.success {
  align-items: center;
  text-align: center;
  padding: 40px 20px;
}

.success-icon {
  color: #10b981;
  margin-bottom: 16px;
}

.step-content.success h3 {
  margin: 0 0 16px 0;
  color: #10b981;
}

.success-message {
  padding: 16px;
  background: rgba(16, 185, 129, 0.1);
  border: 1px solid rgba(16, 185, 129, 0.2);
  border-radius: 6px;
  margin-bottom: 16px;
}

.success-message p {
  margin: 8px 0;
  font-size: 13px;
  color: #cbd5e0;
}

.next-steps {
  text-align: left;
  padding: 16px;
  background: rgba(0, 212, 255, 0.05);
  border: 1px solid rgba(0, 212, 255, 0.1);
  border-radius: 6px;
  margin-bottom: 16px;
}

.next-steps h4 {
  margin: 0 0 12px 0;
  font-size: 13px;
  color: #00d4ff;
}

.next-steps ol {
  margin: 0;
  padding-left: 20px;
  list-style: decimal;
}

.next-steps li {
  font-size: 13px;
  color: #cbd5e0;
  margin: 6px 0;
  line-height: 1.5;
}

@media (max-width: 768px) {
  .checkout-container {
    border-radius: 12px;
  }

  .checkout-steps {
    flex-wrap: wrap;
  }

  .step {
    flex: 1;
    min-width: calc(50% - 8px);
  }

  .step:not(:last-child)::after {
    display: none;
  }

  .actions {
    flex-direction: column;
  }

  .btn-primary,
  .btn-secondary {
    width: 100%;
  }
}
